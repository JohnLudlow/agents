# Files and directories to exclude from npm package

# Development files
.git/
.github/workflows/
.gitignore
.npmrc

# Documentation files (not needed in package)
QUICKSTART.md
CONTRIBUTING.md
docs/plans/
docs/templates/
docs/.gitkeep

# Editor config
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
build/
dist/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Node modules (users will get from npm)
node_modules/

# Test files
test/
tests/
*.test.js
*.spec.js

# Backup files
*.backup
*.tmp
.johnludlow-backup-*
.opencode.johnludlow-backup-*
.copilot.johnludlow-backup-*

# User installation directories (created at install time)
.opencode/
.copilot/
