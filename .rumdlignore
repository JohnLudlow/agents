# rumdl ignore patterns for johnludlow agents repository

# Skill asset templates contain placeholder links
.apm/skills/*/assets/*.md

# Agent definition files (have YAML frontmatter, not standard markdown)
opencode/agents/*.md
.opencode/agents/*.md
.github/agents/*.md

# Node modules
node_modules/

# Ignore opencode backups and generated opencode.* directories
.opencode*
