{
  "description": "Top-level planning agent. Plans only, never implements.",
  "mode": "primary",
  "temperature": 0.3,
  "permission": {
    "read": { "*": "allow" },
    "edit": { "*": "deny", "docs/plans/*": "allow" },
    "bash": {
