{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "grep": {
      "*": "allow"
    },
    "list": {
      "*": "allow"
    },
    "bash": {
      "*": "ask",
      "git log*": "allow",
      "git status*": "allow",
      "git branch*": "allow",
      "git diff*": "allow"
    },
    "edit": "ask",
    "webfetch": "ask"
  },
  "agent": {
    "johnludlow-feature-planner": {
      "description": "Plans features and creates implementation plans - read-only with planning write capabilities",
      "mode": "subagent",
      "temperature": 0.3,
      "permission": {
        "read": {
          "*": "allow"
        },
        "edit": {
          "*": "deny",
          "docs/plans/*": "allow"
        },
        "bash": {
          "*": "deny",
          "git log*": "allow",
          "git status*": "allow",
          "git branch*": "allow",
          "git diff*": "allow"
        },
        "grep": {
          "*": "allow"
        },
        "task": {
          "gh*": "allow",
          "*": "deny"
        }
      }
    },
    "johnludlow-feature-implementer": {
      "description": "Implements features - can write source code and run build/test commands",
      "mode": "subagent",
      "temperature": 0.2,
      "permission": {
        "read": {
          "*": "allow",
          "*.env": "deny"
        },
        "edit": {
          "*": "deny",
          "src/**": "allow",
          "lib/**": "allow",
          "components/**": "allow",
          "*.ts": "allow",
          "*.tsx": "allow",
          "*.cs": "allow",
          "*.cpp": "allow",
          "*.h": "allow"
        },
        "bash": {
          "*": "deny",
          "git log*": "allow",
          "git status*": "allow",
          "git branch*": "allow",
          "git diff*": "allow",
          "npm run build*": "allow",
          "npm run test*": "allow",
          "npm run lint*": "allow",
          "dotnet build*": "allow",
          "dotnet test*": "allow",
          "cargo build*": "allow",
          "cargo test*": "allow"
        },
        "grep": {
          "*": "allow"
        },
        "lsp": "allow"
      }
    },
    "johnludlow-feature-documenter": {
      "description": "Writes and maintains documentation - can write docs and run read-only commands",
      "mode": "subagent",
      "temperature": 0.3,
      "permission": {
        "read": {
          "*": "allow"
        },
        "edit": {
          "*": "deny",
          "docs/**": "allow",
          "docs/plans/*": "allow",
          "README.md": "allow",
          "*.md": "ask"
        },
        "bash": {
          "*": "deny",
          "git log*": "allow",
          "git status*": "allow",
          "git branch*": "allow",
          "git diff*": "allow"
        },
        "grep": {
          "*": "allow"
        },
        "task": {
          "gh*": "allow",
          "*": "deny"
        }
      }
    },
    "johnludlow-feature-tester": {
      "description": "Tests features and reports results - can run tests and post results",
      "mode": "subagent",
      "temperature": 0.2,
      "permission": {
        "read": {
          "*": "allow",
          "*.env": "deny"
        },
        "edit": {
          "*": "deny"
        },
        "bash": {
          "*": "deny",
          "npm test*": "allow",
          "npm run test*": "allow",
          "dotnet test*": "allow",
          "cargo test*": "allow",
          "git log*": "allow",
          "git status*": "allow",
          "git branch*": "allow",
          "git diff*": "allow"
        },
        "grep": {
          "*": "allow"
        }
      }
    }
  }
}
